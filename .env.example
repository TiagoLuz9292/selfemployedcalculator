# Site URL — used by sitemap, OG images, IndexNow, JSON-LD
NEXT_PUBLIC_SITE_URL=https://DOMAIN.com

# IndexNow key — generate with: python3 -c "import uuid; print(uuid.uuid4().hex.upper())"
# Also create public/<key>.txt containing just the key string
INDEXNOW_KEY=YOUR_KEY_HERE

# Optional: protect /api/indexnow with a Bearer token
# CRON_SECRET=your-secret-here

# Optional: enable AdSense ad slots (set to "true" once approved)
# NEXT_PUBLIC_ADS_ENABLED=true
